#!/bin/bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
ROOT_DIR="$(cd "${SCRIPT_PATH%/*}" && pwd)"
BACKEND_DIR="${ROOT_DIR}/backend"

cd "${BACKEND_DIR}"

if command -v conda >/dev/null 2>&1; then
  echo "Using conda env: video"
  exec conda run -n video python gradio_app.py
fi

echo "Using current python environment"
exec python3 gradio_app.py
